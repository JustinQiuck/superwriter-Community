# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Key Storage
# Required before users can save personal AI provider API keys from 设置 -> AI 设置.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Keep the same value across environments if you sync database rows.
AI_CONFIG_SECRET_KEY=change-me-to-a-long-random-secret

# Community edition users should enter provider keys in the app settings page.
# Env keys below are optional development fallbacks for private/commercial deployments.
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# DEEPSEEK_API_KEY=your-deepseek-key
# OPENROUTER_API_KEY=your-openrouter-key

# Embedding
# Recommended: keep 1536 dimensions because story_archival_memories.content_embedding is vector(1536).
# If EMBEDDING_PROVIDER=openai, uncomment OPENAI_API_KEY above or provide an OpenAI-compatible embedding key.
EMBEDDING_PROVIDER=openai
# Defaults by provider: openai=text-embedding-3-small, dashscope=text-embedding-v4, zhipu=Embedding-3
EMBEDDING_MODEL=
# Optional OpenAI-compatible endpoint override for embedding only.
EMBEDDING_BASE_URL=
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# Optional embedding provider env examples if you do not use OpenAI-compatible defaults above.
# MY_OPENAI_COMPATIBLE_API_KEY=your-provider-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SuperWriter

# Edition
# Public/community builds should stay in community mode.
NEXT_PUBLIC_SUPERWRITER_EDITION=community
# Private commercial deployments can set both values below.
SUPERWRITER_ENABLE_ADMIN=false
NEXT_PUBLIC_COMMUNITY_URL=
